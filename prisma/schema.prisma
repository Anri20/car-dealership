// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model master_users {
  id       Int    @id @default(autoincrement())
  username String
  email    String @unique
  password String

  cars_created master_cars[] @relation("CarCreatedBy")
  cars_updated master_cars[] @relation("CarUpdatedBy")
  cars_deleted master_cars[] @relation("CarDeletedBy")
}

model master_cars {
  id              Int    @id @default(autoincrement())
  type_id         Int
  transmission_id Int
  name            String
  desc            String @db.Text
  year            Int    @db.SmallInt
  odometer        Int
  price           Int
  credit          Int

  created_by Int
  updated_by Int?
  deleted_by Int?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  car_types         car_types         @relation(fields: [type_id], references: [id])
  car_transmissions car_transmissions @relation(fields: [transmission_id], references: [id])
  car_images        car_images[]
  creator           master_users      @relation("CarCreatedBy", fields: [created_by], references: [id])
  updater           master_users?     @relation("CarUpdatedBy", fields: [updated_by], references: [id])
  deletor           master_users?     @relation("CarDeletedBy", fields: [deleted_by], references: [id])
}

model car_images {
  id     Int @id @default(autoincrement())
  car_id Int

  url       String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  created_at DateTime @default(now())

  car master_cars @relation(fields: [car_id], references: [id])
}

model car_types {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  cars master_cars[]
}

model car_transmissions {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  cars master_cars[]
}
